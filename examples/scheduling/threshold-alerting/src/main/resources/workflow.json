{
  "name": "threshold_alerting_423",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": [
    "metricName",
    "currentValue",
    "warningThreshold",
    "criticalThreshold"
  ],
  "tasks": [
    {
      "name": "th_check_metric",
      "taskReferenceName": "th_check_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "metricName": "${workflow.input.metricName}",
        "currentValue": "${workflow.input.currentValue}",
        "warningThreshold": "${workflow.input.warningThreshold}",
        "criticalThreshold": "${workflow.input.criticalThreshold}"
      }
    },
    {
      "name": "th_severity_switch",
      "taskReferenceName": "th_switch_ref",
      "type": "SWITCH",
      "evaluatorType": "value-param",
      "expression": "switchCaseValue",
      "inputParameters": {
        "switchCaseValue": "${th_check_ref.output.severity}"
      },
      "decisionCases": {
        "critical": [
          {
            "name": "th_page_oncall",
            "taskReferenceName": "th_page_ref",
            "type": "SIMPLE",
            "inputParameters": {
              "metricName": "${workflow.input.metricName}",
              "currentValue": "${workflow.input.currentValue}",
              "severity": "critical"
            }
          }
        ],
        "warning": [
          {
            "name": "th_send_warning",
            "taskReferenceName": "th_warn_ref",
            "type": "SIMPLE",
            "inputParameters": {
              "metricName": "${workflow.input.metricName}",
              "currentValue": "${workflow.input.currentValue}",
              "severity": "warning"
            }
          }
        ]
      },
      "defaultCase": [
        {
          "name": "th_log_ok",
          "taskReferenceName": "th_ok_ref",
          "type": "SIMPLE",
          "inputParameters": {
            "metricName": "${workflow.input.metricName}",
            "currentValue": "${workflow.input.currentValue}"
          }
        }
      ]
    }
  ],
  "outputParameters": {
    "severity": "${th_check_ref.output.severity}",
    "metricName": "${workflow.input.metricName}",
    "currentValue": "${workflow.input.currentValue}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}