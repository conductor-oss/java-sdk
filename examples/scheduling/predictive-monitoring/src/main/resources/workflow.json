{
  "name": "predictive_monitoring_424",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": [
    "metricName",
    "historyDays",
    "forecastHours"
  ],
  "tasks": [
    {
      "name": "pdm_collect_history",
      "taskReferenceName": "pdm_collect_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "metricName": "${workflow.input.metricName}",
        "historyDays": "${workflow.input.historyDays}"
      }
    },
    {
      "name": "pdm_train_model",
      "taskReferenceName": "pdm_train_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "dataPoints": "${pdm_collect_ref.output.dataPoints}",
        "metricName": "${workflow.input.metricName}"
      }
    },
    {
      "name": "pdm_predict",
      "taskReferenceName": "pdm_predict_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "modelId": "${pdm_train_ref.output.modelId}",
        "forecastHours": "${workflow.input.forecastHours}",
        "modelAccuracy": "${pdm_train_ref.output.accuracy}"
      }
    },
    {
      "name": "pdm_alert",
      "taskReferenceName": "pdm_alert_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "metricName": "${workflow.input.metricName}",
        "predictedPeak": "${pdm_predict_ref.output.predictedPeak}",
        "breachLikelihood": "${pdm_predict_ref.output.breachLikelihood}"
      }
    }
  ],
  "outputParameters": {
    "dataPoints": "${pdm_collect_ref.output.dataPoints}",
    "modelAccuracy": "${pdm_train_ref.output.accuracy}",
    "predictedPeak": "${pdm_predict_ref.output.predictedPeak}",
    "breachLikelihood": "${pdm_predict_ref.output.breachLikelihood}",
    "alertSent": "${pdm_alert_ref.output.alertSent}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}