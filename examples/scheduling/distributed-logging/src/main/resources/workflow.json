 {"name":"dg_join_collect","taskReferenceName":"dg_join_ref","type":"JOIN","joinOn":["dg_svc1_ref","dg_svc2_ref","dg_svc3_ref"]},
 {"name":"dg_correlate","taskReferenceName":"dg_correlate_ref","type":"SIMPLE","inputParameters":{"svc1Logs":"${dg_svc1_ref.output.logCount}","svc2Logs":"${dg_svc2_ref.output.logCount}","svc3Logs":"${dg_svc3_ref.output.logCount}","traceId":"${workflow.input.traceId}"}}
