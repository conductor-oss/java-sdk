{
  "name": "custom_metrics_422",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": [
    "metricDefinitions",
    "collectionInterval",
    "aggregationWindow"
  ],
  "tasks": [
    {
      "name": "cus_define_metrics",
      "taskReferenceName": "cus_define_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "metricDefinitions": "${workflow.input.metricDefinitions}"
      }
    },
    {
      "name": "cus_collect_data",
      "taskReferenceName": "cus_collect_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "registeredMetrics": "${cus_define_ref.output.registeredMetrics}",
        "collectionInterval": "${workflow.input.collectionInterval}"
      }
    },
    {
      "name": "cus_aggregate",
      "taskReferenceName": "cus_aggregate_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "rawDataPoints": "${cus_collect_ref.output.rawDataPoints}",
        "aggregationWindow": "${workflow.input.aggregationWindow}"
      }
    },
    {
      "name": "cus_update_dashboard",
      "taskReferenceName": "cus_dashboard_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "aggregatedMetrics": "${cus_aggregate_ref.output.aggregatedMetrics}",
        "metricCount": "${cus_aggregate_ref.output.metricCount}"
      }
    }
  ],
  "outputParameters": {
    "registeredMetrics": "${cus_define_ref.output.registeredMetrics}",
    "rawDataPoints": "${cus_collect_ref.output.rawDataPoints}",
    "metricCount": "${cus_aggregate_ref.output.metricCount}",
    "dashboardUpdated": "${cus_dashboard_ref.output.dashboardUpdated}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}