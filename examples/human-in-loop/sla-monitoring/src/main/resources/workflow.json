{
  "name": "sla_monitoring_demo",
  "description": "SLA Monitoring -- process request, wait for human approval, then record SLA metrics.",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["slaMs"],
  "tasks": [
    {
      "name": "sla_process",
      "taskReferenceName": "sla_process_ref",
      "type": "SIMPLE",
      "inputParameters": {}
    },
    {
      "name": "sla_wait",
      "taskReferenceName": "sla_wait_ref",
      "type": "WAIT",
      "inputParameters": {}
    },
    {
      "name": "sla_record_metrics",
      "taskReferenceName": "sla_record_metrics_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "waitStartTime": "${sla_wait_ref.startTime}",
        "waitEndTime": "${sla_wait_ref.endTime}",
        "slaMs": "${workflow.input.slaMs}"
      }
    }
  ],
  "outputParameters": {
    "processed": "${sla_process_ref.output.processed}",
    "waitDurationMs": "${sla_record_metrics_ref.output.waitDurationMs}",
    "slaMet": "${sla_record_metrics_ref.output.slaMet}",
    "slaMs": "${sla_record_metrics_ref.output.slaMs}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 300
}
