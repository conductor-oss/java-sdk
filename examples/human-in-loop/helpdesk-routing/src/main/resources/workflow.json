{
  "name": "hdr_helpdesk_routing",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["issueDescription", "customerId"],
  "tasks": [
    { "name": "hdr_classify", "taskReferenceName": "hdr_classify_ref", "type": "SIMPLE", "inputParameters": { "description": "${workflow.input.issueDescription}", "customerId": "${workflow.input.customerId}" } },
    {
      "name": "hdr_route_switch",
      "taskReferenceName": "hdr_switch_ref",
      "type": "SWITCH",
      "evaluatorType": "value-param",
      "expression": "switchCaseValue",
      "inputParameters": { "switchCaseValue": "${hdr_classify_ref.output.tier}" },
      "decisionCases": {
        "tier1": [{ "name": "hdr_tier1", "taskReferenceName": "hdr_tier1_ref", "type": "SIMPLE", "inputParameters": { "issue": "${workflow.input.issueDescription}", "customerId": "${workflow.input.customerId}" } }],
        "tier2": [{ "name": "hdr_tier2", "taskReferenceName": "hdr_tier2_ref", "type": "SIMPLE", "inputParameters": { "issue": "${workflow.input.issueDescription}", "customerId": "${workflow.input.customerId}" } }],
        "tier3": [{ "name": "hdr_tier3", "taskReferenceName": "hdr_tier3_ref", "type": "SIMPLE", "inputParameters": { "issue": "${workflow.input.issueDescription}", "customerId": "${workflow.input.customerId}" } }]
      },
      "defaultCase": [{ "name": "hdr_tier1", "taskReferenceName": "hdr_default_ref", "type": "SIMPLE", "inputParameters": { "issue": "${workflow.input.issueDescription}", "customerId": "${workflow.input.customerId}" } }]
    }
  ],
  "outputParameters": {
    "tier": "${hdr_classify_ref.output.tier}",
    "resolution": "${hdr_classify_ref.output.tier}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
