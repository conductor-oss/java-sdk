{"name":"risk_management_726","description":"Risk management with SWITCH for high/medium/low severity.","version":1,"schemaVersion":2,"inputParameters":["projectId","riskDescription"],"tasks":[{"name":"rkm_identify","taskReferenceName":"identify_ref","type":"SIMPLE","inputParameters":{"projectId":"${workflow.input.projectId}","description":"${workflow.input.riskDescription}"}},{"name":"rkm_assess","taskReferenceName":"assess_ref","type":"SIMPLE","inputParameters":{"risk":"${identify_ref.output.risk}"}},{"name":"route_risk","taskReferenceName":"switch_ref","type":"SWITCH","evaluatorType":"value-param","expression":"switchCaseValue","inputParameters":{"switchCaseValue":"${assess_ref.output.severity}"},"decisionCases":{"high":[{"name":"rkm_high","taskReferenceName":"high_ref","type":"SIMPLE","inputParameters":{"risk":"${identify_ref.output.risk}"}}],"medium":[{"name":"rkm_medium","taskReferenceName":"medium_ref","type":"SIMPLE","inputParameters":{"risk":"${identify_ref.output.risk}"}}]},"defaultCase":[{"name":"rkm_low","taskReferenceName":"low_ref","type":"SIMPLE","inputParameters":{"risk":"${identify_ref.output.risk}"}}]},{"name":"rkm_mitigate","taskReferenceName":"mitigate_ref","type":"SIMPLE","inputParameters":{"projectId":"${workflow.input.projectId}","severity":"${assess_ref.output.severity}"}}],"outputParameters":{"mitigation":"${mitigate_ref.output.plan}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
