{
  "name": "data_migration",
  "description": "Data migration workflow that extracts records from a source, validates, transforms schema, loads into target, and verifies the migration.",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": [
    "sourceConfig",
    "targetConfig",
    "batchSize"
  ],
  "tasks": [
    {
      "name": "mi_extract_source",
      "taskReferenceName": "extract_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "sourceConfig": "${workflow.input.sourceConfig}",
        "batchSize": "${workflow.input.batchSize}"
      }
    },
    {
      "name": "mi_validate_source",
      "taskReferenceName": "validate_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "records": "${extract_ref.output.records}",
        "schema": "${extract_ref.output.schema}"
      }
    },
    {
      "name": "mi_transform_schema",
      "taskReferenceName": "transform_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "validRecords": "${validate_ref.output.validRecords}",
        "targetConfig": "${workflow.input.targetConfig}"
      }
    },
    {
      "name": "mi_load_target",
      "taskReferenceName": "load_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "transformedRecords": "${transform_ref.output.transformed}",
        "targetConfig": "${workflow.input.targetConfig}"
      }
    },
    {
      "name": "mi_verify_migration",
      "taskReferenceName": "verify_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "sourceCount": "${extract_ref.output.recordCount}",
        "loadedCount": "${load_ref.output.loadedCount}",
        "targetConfig": "${workflow.input.targetConfig}"
      }
    }
  ],
  "outputParameters": {
    "sourceRecords": "${extract_ref.output.recordCount}",
    "validRecords": "${validate_ref.output.validCount}",
    "transformedRecords": "${transform_ref.output.transformedCount}",
    "loadedRecords": "${load_ref.output.loadedCount}",
    "verificationStatus": "${verify_ref.output.status}",
    "migrationSummary": "${verify_ref.output.summary}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
