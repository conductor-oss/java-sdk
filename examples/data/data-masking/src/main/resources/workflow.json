{
  "name": "data_masking",
  "description": "Data masking workflow: load records, detect PII, mask SSN, mask email/phone, and emit masked results.",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": [
    "records",
    "maskingPolicy"
  ],
  "tasks": [
    {
      "name": "mk_load_records",
      "taskReferenceName": "load_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "records": "${workflow.input.records}"
      }
    },
    {
      "name": "mk_detect_pii",
      "taskReferenceName": "detect_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "records": "${load_ref.output.records}",
        "policy": "${workflow.input.maskingPolicy}"
      }
    },
    {
      "name": "mk_mask_ssn",
      "taskReferenceName": "ssn_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "records": "${detect_ref.output.records}",
        "piiFields": "${detect_ref.output.piiFields}"
      }
    },
    {
      "name": "mk_mask_email_phone",
      "taskReferenceName": "contact_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "records": "${ssn_ref.output.records}",
        "piiFields": "${detect_ref.output.piiFields}"
      }
    },
    {
      "name": "mk_emit_masked",
      "taskReferenceName": "emit_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "records": "${contact_ref.output.records}",
        "fieldsDetected": "${detect_ref.output.piiFieldCount}",
        "recordCount": "${load_ref.output.count}"
      }
    }
  ],
  "outputParameters": {
    "totalRecords": "${load_ref.output.count}",
    "piiFieldsDetected": "${detect_ref.output.piiFieldCount}",
    "ssnsMasked": "${ssn_ref.output.maskedCount}",
    "contactsMasked": "${contact_ref.output.maskedCount}",
    "summary": "${emit_ref.output.summary}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
