{"name":"cryptocurrency_trading_workflow","description":"Crypto trading: monitor market, analyze signals, SWITCH(buy/sell/hold), confirm.","version":1,"schemaVersion":2,"inputParameters":["pair","portfolioId","strategy"],"tasks":[{"name":"cry_monitor_market","taskReferenceName":"cry_monitor_ref","type":"SIMPLE","inputParameters":{"pair":"${workflow.input.pair}","portfolioId":"${workflow.input.portfolioId}"}},{"name":"cry_analyze_signals","taskReferenceName":"cry_signals_ref","type":"SIMPLE","inputParameters":{"pair":"${workflow.input.pair}","strategy":"${workflow.input.strategy}","currentPrice":"${cry_monitor_ref.output.currentPrice}","marketData":"${cry_monitor_ref.output.marketData}"}},{"name":"cry_trade_decision","taskReferenceName":"cry_switch_ref","type":"SWITCH","evaluatorType":"value-param","expression":"switchCaseValue","inputParameters":{"switchCaseValue":"${cry_signals_ref.output.signal}"},"decisionCases":{"buy":[{"name":"cry_execute_buy","taskReferenceName":"cry_buy_ref","type":"SIMPLE","inputParameters":{"pair":"${workflow.input.pair}","portfolioId":"${workflow.input.portfolioId}","amount":"${cry_signals_ref.output.suggestedAmount}","price":"${cry_monitor_ref.output.currentPrice}"}}],"sell":[{"name":"cry_execute_sell","taskReferenceName":"cry_sell_ref","type":"SIMPLE","inputParameters":{"pair":"${workflow.input.pair}","portfolioId":"${workflow.input.portfolioId}","amount":"${cry_signals_ref.output.suggestedAmount}","price":"${cry_monitor_ref.output.currentPrice}"}}],"hold":[{"name":"cry_execute_hold","taskReferenceName":"cry_hold_ref","type":"SIMPLE","inputParameters":{"pair":"${workflow.input.pair}","portfolioId":"${workflow.input.portfolioId}","reason":"${cry_signals_ref.output.holdReason}"}}]},"defaultCase":[]},{"name":"cry_confirm_action","taskReferenceName":"cry_confirm_ref","type":"SIMPLE","inputParameters":{"pair":"${workflow.input.pair}","portfolioId":"${workflow.input.portfolioId}","signal":"${cry_signals_ref.output.signal}"}}],"outputParameters":{"pair":"${workflow.input.pair}","signal":"${cry_signals_ref.output.signal}","currentPrice":"${cry_monitor_ref.output.currentPrice}","actionConfirmed":"${cry_confirm_ref.output.confirmed}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
