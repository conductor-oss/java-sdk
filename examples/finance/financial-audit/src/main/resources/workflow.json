{"name":"financial_audit_workflow","description":"Financial audit: define scope, collect evidence, test controls, generate report, remediate.","version":1,"schemaVersion":2,"inputParameters":["auditId","entityName","auditType","fiscalYear"],"tasks":[{"name":"fau_define_scope","taskReferenceName":"fau_scope_ref","type":"SIMPLE","inputParameters":{"auditId":"${workflow.input.auditId}","entityName":"${workflow.input.entityName}","auditType":"${workflow.input.auditType}","fiscalYear":"${workflow.input.fiscalYear}"}},{"name":"fau_collect_evidence","taskReferenceName":"fau_evidence_ref","type":"SIMPLE","inputParameters":{"auditId":"${workflow.input.auditId}","scopeAreas":"${fau_scope_ref.output.scopeAreas}","materialityThreshold":"${fau_scope_ref.output.materialityThreshold}"}},{"name":"fau_test_controls","taskReferenceName":"fau_controls_ref","type":"SIMPLE","inputParameters":{"auditId":"${workflow.input.auditId}","evidenceItems":"${fau_evidence_ref.output.evidenceCount}","controlAreas":"${fau_scope_ref.output.scopeAreas}"}},{"name":"fau_generate_report","taskReferenceName":"fau_report_ref","type":"SIMPLE","inputParameters":{"auditId":"${workflow.input.auditId}","entityName":"${workflow.input.entityName}","findings":"${fau_controls_ref.output.findings}","controlEffectiveness":"${fau_controls_ref.output.controlEffectiveness}"}},{"name":"fau_remediate","taskReferenceName":"fau_remediate_ref","type":"SIMPLE","inputParameters":{"auditId":"${workflow.input.auditId}","findingsCount":"${fau_controls_ref.output.findingsCount}","reportId":"${fau_report_ref.output.reportId}"}}],"outputParameters":{"auditId":"${workflow.input.auditId}","controlEffectiveness":"${fau_controls_ref.output.controlEffectiveness}","reportId":"${fau_report_ref.output.reportId}","remediationPlanId":"${fau_remediate_ref.output.remediationPlanId}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
