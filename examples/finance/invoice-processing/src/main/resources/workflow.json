{"name":"invoice_processing_workflow","description":"Invoice processing: receive, OCR extract, match PO, approve, process payment.","version":1,"schemaVersion":2,"inputParameters":["invoiceId","vendorId","documentUrl"],"tasks":[{"name":"ivc_receive_invoice","taskReferenceName":"ivc_receive_ref","type":"SIMPLE","inputParameters":{"invoiceId":"${workflow.input.invoiceId}","vendorId":"${workflow.input.vendorId}","documentUrl":"${workflow.input.documentUrl}"}},{"name":"ivc_ocr_extract","taskReferenceName":"ivc_ocr_ref","type":"SIMPLE","inputParameters":{"invoiceId":"${workflow.input.invoiceId}","documentUrl":"${workflow.input.documentUrl}"}},{"name":"ivc_match_po","taskReferenceName":"ivc_match_ref","type":"SIMPLE","inputParameters":{"invoiceId":"${workflow.input.invoiceId}","vendorId":"${workflow.input.vendorId}","extractedAmount":"${ivc_ocr_ref.output.amount}","extractedPoNumber":"${ivc_ocr_ref.output.poNumber}"}},{"name":"ivc_approve_invoice","taskReferenceName":"ivc_approve_ref","type":"SIMPLE","inputParameters":{"invoiceId":"${workflow.input.invoiceId}","amount":"${ivc_ocr_ref.output.amount}","poMatched":"${ivc_match_ref.output.matched}","poNumber":"${ivc_match_ref.output.poNumber}"}},{"name":"ivc_process_payment","taskReferenceName":"ivc_pay_ref","type":"SIMPLE","inputParameters":{"invoiceId":"${workflow.input.invoiceId}","vendorId":"${workflow.input.vendorId}","amount":"${ivc_ocr_ref.output.amount}","approved":"${ivc_approve_ref.output.approved}"}}],"outputParameters":{"invoiceId":"${workflow.input.invoiceId}","amount":"${ivc_ocr_ref.output.amount}","paymentStatus":"${ivc_pay_ref.output.paymentStatus}","paymentId":"${ivc_pay_ref.output.paymentId}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
