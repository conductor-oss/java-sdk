{"name":"investment_workflow","description":"Investment lifecycle: research, analyze, decide, execute, monitor.","version":1,"schemaVersion":2,"inputParameters":["tickerSymbol","investorId","maxInvestment"],"tasks":[{"name":"ivt_research","taskReferenceName":"ivt_research_ref","type":"SIMPLE","inputParameters":{"tickerSymbol":"${workflow.input.tickerSymbol}","investorId":"${workflow.input.investorId}"}},{"name":"ivt_analyze","taskReferenceName":"ivt_analyze_ref","type":"SIMPLE","inputParameters":{"tickerSymbol":"${workflow.input.tickerSymbol}","fundamentals":"${ivt_research_ref.output.fundamentals}","marketData":"${ivt_research_ref.output.marketData}"}},{"name":"ivt_decide","taskReferenceName":"ivt_decide_ref","type":"SIMPLE","inputParameters":{"tickerSymbol":"${workflow.input.tickerSymbol}","maxInvestment":"${workflow.input.maxInvestment}","riskScore":"${ivt_analyze_ref.output.riskScore}","expectedReturn":"${ivt_analyze_ref.output.expectedReturn}","recommendation":"${ivt_analyze_ref.output.recommendation}"}},{"name":"ivt_execute","taskReferenceName":"ivt_execute_ref","type":"SIMPLE","inputParameters":{"tickerSymbol":"${workflow.input.tickerSymbol}","investorId":"${workflow.input.investorId}","action":"${ivt_decide_ref.output.action}","shares":"${ivt_decide_ref.output.shares}","priceLimit":"${ivt_decide_ref.output.priceLimit}"}},{"name":"ivt_monitor","taskReferenceName":"ivt_monitor_ref","type":"SIMPLE","inputParameters":{"tickerSymbol":"${workflow.input.tickerSymbol}","investorId":"${workflow.input.investorId}","tradeId":"${ivt_execute_ref.output.tradeId}","executedPrice":"${ivt_execute_ref.output.executedPrice}"}}],"outputParameters":{"tickerSymbol":"${workflow.input.tickerSymbol}","action":"${ivt_decide_ref.output.action}","tradeId":"${ivt_execute_ref.output.tradeId}","monitoringStatus":"${ivt_monitor_ref.output.monitoringStatus}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
