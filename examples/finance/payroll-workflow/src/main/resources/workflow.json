{"name":"payroll_workflow","description":"Payroll processing: collect hours, calculate gross, apply deductions, process, distribute stubs.","version":1,"schemaVersion":2,"inputParameters":["payPeriodId","departmentId"],"tasks":[{"name":"prl_collect_hours","taskReferenceName":"prl_hours_ref","type":"SIMPLE","inputParameters":{"payPeriodId":"${workflow.input.payPeriodId}","departmentId":"${workflow.input.departmentId}"}},{"name":"prl_calculate_gross","taskReferenceName":"prl_gross_ref","type":"SIMPLE","inputParameters":{"payPeriodId":"${workflow.input.payPeriodId}","employeeRecords":"${prl_hours_ref.output.employeeRecords}"}},{"name":"prl_apply_deductions","taskReferenceName":"prl_deductions_ref","type":"SIMPLE","inputParameters":{"payPeriodId":"${workflow.input.payPeriodId}","grossPayroll":"${prl_gross_ref.output.grossPayroll}","employeeCount":"${prl_gross_ref.output.employeeCount}"}},{"name":"prl_process_payroll","taskReferenceName":"prl_process_ref","type":"SIMPLE","inputParameters":{"payPeriodId":"${workflow.input.payPeriodId}","netPayroll":"${prl_deductions_ref.output.netPayroll}","totalDeductions":"${prl_deductions_ref.output.totalDeductions}"}},{"name":"prl_distribute_stubs","taskReferenceName":"prl_distribute_ref","type":"SIMPLE","inputParameters":{"payPeriodId":"${workflow.input.payPeriodId}","processedBatchId":"${prl_process_ref.output.batchId}","employeeCount":"${prl_gross_ref.output.employeeCount}"}}],"outputParameters":{"payPeriodId":"${workflow.input.payPeriodId}","grossPayroll":"${prl_gross_ref.output.grossPayroll}","netPayroll":"${prl_deductions_ref.output.netPayroll}","employeesProcessed":"${prl_distribute_ref.output.distributedCount}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
