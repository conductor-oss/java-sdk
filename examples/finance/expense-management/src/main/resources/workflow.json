{"name":"expense_management_workflow","description":"Expense management: submit, validate receipts, categorize, approve, reimburse.","version":1,"schemaVersion":2,"inputParameters":["expenseId","employeeId","amount","category","receiptUrl"],"tasks":[{"name":"exp_submit_expense","taskReferenceName":"exp_submit_ref","type":"SIMPLE","inputParameters":{"expenseId":"${workflow.input.expenseId}","employeeId":"${workflow.input.employeeId}","amount":"${workflow.input.amount}","category":"${workflow.input.category}"}},{"name":"exp_validate_receipts","taskReferenceName":"exp_validate_ref","type":"SIMPLE","inputParameters":{"expenseId":"${workflow.input.expenseId}","receiptUrl":"${workflow.input.receiptUrl}","amount":"${workflow.input.amount}"}},{"name":"exp_categorize","taskReferenceName":"exp_categorize_ref","type":"SIMPLE","inputParameters":{"expenseId":"${workflow.input.expenseId}","category":"${workflow.input.category}","receiptValid":"${exp_validate_ref.output.valid}"}},{"name":"exp_approve_expense","taskReferenceName":"exp_approve_ref","type":"SIMPLE","inputParameters":{"expenseId":"${workflow.input.expenseId}","employeeId":"${workflow.input.employeeId}","amount":"${workflow.input.amount}","finalCategory":"${exp_categorize_ref.output.finalCategory}"}},{"name":"exp_reimburse","taskReferenceName":"exp_reimburse_ref","type":"SIMPLE","inputParameters":{"expenseId":"${workflow.input.expenseId}","employeeId":"${workflow.input.employeeId}","approvedAmount":"${exp_approve_ref.output.approvedAmount}"}}],"outputParameters":{"expenseId":"${workflow.input.expenseId}","approvedAmount":"${exp_approve_ref.output.approvedAmount}","reimbursementStatus":"${exp_reimburse_ref.output.reimbursementStatus}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
