{"name":"budget_approval_workflow","description":"Budget approval with SWITCH for approve/revise/reject decisions.","version":1,"schemaVersion":2,"inputParameters":["budgetId","department","amount","justification"],"tasks":[{"name":"bgt_submit_budget","taskReferenceName":"bgt_submit_ref","type":"SIMPLE","inputParameters":{"budgetId":"${workflow.input.budgetId}","department":"${workflow.input.department}","amount":"${workflow.input.amount}","justification":"${workflow.input.justification}"}},{"name":"bgt_review_budget","taskReferenceName":"bgt_review_ref","type":"SIMPLE","inputParameters":{"budgetId":"${workflow.input.budgetId}","department":"${workflow.input.department}","amount":"${workflow.input.amount}","submissionId":"${bgt_submit_ref.output.submissionId}"}},{"name":"bgt_decision","taskReferenceName":"bgt_switch_ref","type":"SWITCH","evaluatorType":"value-param","expression":"switchCaseValue","inputParameters":{"switchCaseValue":"${bgt_review_ref.output.decision}"},"decisionCases":{"approve":[{"name":"bgt_approve_budget","taskReferenceName":"bgt_approve_ref","type":"SIMPLE","inputParameters":{"budgetId":"${workflow.input.budgetId}","amount":"${workflow.input.amount}","approver":"${bgt_review_ref.output.reviewer}"}}],"revise":[{"name":"bgt_revise_budget","taskReferenceName":"bgt_revise_ref","type":"SIMPLE","inputParameters":{"budgetId":"${workflow.input.budgetId}","amount":"${workflow.input.amount}","revisedAmount":"${bgt_review_ref.output.revisedAmount}","comments":"${bgt_review_ref.output.comments}"}}],"reject":[{"name":"bgt_reject_budget","taskReferenceName":"bgt_reject_ref","type":"SIMPLE","inputParameters":{"budgetId":"${workflow.input.budgetId}","reason":"${bgt_review_ref.output.comments}"}}]},"defaultCase":[]},{"name":"bgt_allocate_funds","taskReferenceName":"bgt_allocate_ref","type":"SIMPLE","inputParameters":{"budgetId":"${workflow.input.budgetId}","department":"${workflow.input.department}","decision":"${bgt_review_ref.output.decision}"}}],"outputParameters":{"budgetId":"${workflow.input.budgetId}","decision":"${bgt_review_ref.output.decision}","allocationStatus":"${bgt_allocate_ref.output.allocationStatus}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
