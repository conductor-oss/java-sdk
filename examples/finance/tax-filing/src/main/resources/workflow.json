{"name":"tax_filing_workflow","description":"Tax filing: collect data, calculate tax, validate, file return, confirm.","version":1,"schemaVersion":2,"inputParameters":["taxpayerId","taxYear","filingType"],"tasks":[{"name":"txf_collect_data","taskReferenceName":"txf_collect_ref","type":"SIMPLE","inputParameters":{"taxpayerId":"${workflow.input.taxpayerId}","taxYear":"${workflow.input.taxYear}","filingType":"${workflow.input.filingType}"}},{"name":"txf_calculate_tax","taskReferenceName":"txf_calculate_ref","type":"SIMPLE","inputParameters":{"taxpayerId":"${workflow.input.taxpayerId}","grossIncome":"${txf_collect_ref.output.grossIncome}","deductions":"${txf_collect_ref.output.deductions}","credits":"${txf_collect_ref.output.credits}"}},{"name":"txf_validate_filing","taskReferenceName":"txf_validate_ref","type":"SIMPLE","inputParameters":{"taxpayerId":"${workflow.input.taxpayerId}","taxLiability":"${txf_calculate_ref.output.taxLiability}","effectiveRate":"${txf_calculate_ref.output.effectiveRate}"}},{"name":"txf_file_return","taskReferenceName":"txf_file_ref","type":"SIMPLE","inputParameters":{"taxpayerId":"${workflow.input.taxpayerId}","taxYear":"${workflow.input.taxYear}","taxLiability":"${txf_calculate_ref.output.taxLiability}","validated":"${txf_validate_ref.output.validated}"}},{"name":"txf_confirm_submission","taskReferenceName":"txf_confirm_ref","type":"SIMPLE","inputParameters":{"taxpayerId":"${workflow.input.taxpayerId}","filingId":"${txf_file_ref.output.filingId}","confirmationNumber":"${txf_file_ref.output.confirmationNumber}"}}],"outputParameters":{"taxpayerId":"${workflow.input.taxpayerId}","taxLiability":"${txf_calculate_ref.output.taxLiability}","filingId":"${txf_file_ref.output.filingId}","confirmationNumber":"${txf_file_ref.output.confirmationNumber}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
