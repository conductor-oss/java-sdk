{
  "name": "prr_pr_review",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["repoName", "prNumber"],
  "tasks": [
    { "name": "prr_fetch_diff", "taskReferenceName": "prr_fetch_ref", "type": "SIMPLE", "inputParameters": { "repoName": "${workflow.input.repoName}", "prNumber": "${workflow.input.prNumber}" } },
    { "name": "prr_analyze_changes", "taskReferenceName": "prr_analyze_ref", "type": "SIMPLE", "inputParameters": { "diff": "${prr_fetch_ref.output.diff}" } },
    { "name": "prr_generate_review", "taskReferenceName": "prr_review_ref", "type": "SIMPLE", "inputParameters": { "analysis": "${prr_analyze_ref.output.analysis}" } },
    { "name": "prr_post_review", "taskReferenceName": "prr_post_ref", "type": "SIMPLE", "inputParameters": { "review": "${prr_review_ref.output.review}", "prNumber": "${workflow.input.prNumber}" } }
  ],
  "outputParameters": {
    "filesChanged": "${prr_fetch_ref.output.filesChanged}",
    "issuesFound": "${prr_analyze_ref.output.issueCount}",
    "verdict": "${prr_review_ref.output.verdict}",
    "posted": "${prr_post_ref.output.posted}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
