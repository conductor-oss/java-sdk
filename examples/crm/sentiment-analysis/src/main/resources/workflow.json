{
  "name": "snt_sentiment_analysis",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["texts", "source"],
  "tasks": [
    { "name": "snt_preprocess", "taskReferenceName": "snt_preprocess_ref", "type": "SIMPLE", "inputParameters": { "texts": "${workflow.input.texts}" } },
    { "name": "snt_analyze", "taskReferenceName": "snt_analyze_ref", "type": "SIMPLE", "inputParameters": { "cleanedTexts": "${snt_preprocess_ref.output.cleanedTexts}" } },
    { "name": "snt_classify", "taskReferenceName": "snt_classify_ref", "type": "SIMPLE", "inputParameters": { "sentiments": "${snt_analyze_ref.output.sentiments}" } },
    { "name": "snt_aggregate", "taskReferenceName": "snt_agg_ref", "type": "SIMPLE", "inputParameters": { "classifications": "${snt_classify_ref.output.classifications}", "source": "${workflow.input.source}" } }
  ],
  "outputParameters": {
    "textsProcessed": "${snt_preprocess_ref.output.processedCount}",
    "overallSentiment": "${snt_agg_ref.output.overallSentiment}",
    "distribution": "${snt_agg_ref.output.distribution}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
