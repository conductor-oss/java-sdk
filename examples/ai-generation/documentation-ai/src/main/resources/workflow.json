{
  "name": "doc_documentation_ai",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["repoPath", "outputFormat"],
  "tasks": [
    { "name": "doc_analyze_code", "taskReferenceName": "doc_analyze_ref", "type": "SIMPLE", "inputParameters": { "repoPath": "${workflow.input.repoPath}" } },
    { "name": "doc_generate_docs", "taskReferenceName": "doc_generate_ref", "type": "SIMPLE", "inputParameters": { "modules": "${doc_analyze_ref.output.modules}" } },
    { "name": "doc_format", "taskReferenceName": "doc_format_ref", "type": "SIMPLE", "inputParameters": { "rawDocs": "${doc_generate_ref.output.rawDocs}", "outputFormat": "${workflow.input.outputFormat}" } },
    { "name": "doc_publish", "taskReferenceName": "doc_publish_ref", "type": "SIMPLE", "inputParameters": { "formattedDocs": "${doc_format_ref.output.formattedDocs}" } }
  ],
  "outputParameters": {
    "moduleCount": "${doc_analyze_ref.output.moduleCount}",
    "pagesGenerated": "${doc_generate_ref.output.pageCount}",
    "format": "${doc_format_ref.output.format}",
    "publishUrl": "${doc_publish_ref.output.publishUrl}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
