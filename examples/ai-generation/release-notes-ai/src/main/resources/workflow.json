{
  "name": "rna_release_notes",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["repoName", "fromTag", "toTag"],
  "tasks": [
    { "name": "rna_collect_commits", "taskReferenceName": "rna_collect_ref", "type": "SIMPLE", "inputParameters": { "repoName": "${workflow.input.repoName}", "fromTag": "${workflow.input.fromTag}", "toTag": "${workflow.input.toTag}" } },
    { "name": "rna_categorize", "taskReferenceName": "rna_categorize_ref", "type": "SIMPLE", "inputParameters": { "commits": "${rna_collect_ref.output.commits}" } },
    { "name": "rna_generate_notes", "taskReferenceName": "rna_generate_ref", "type": "SIMPLE", "inputParameters": { "categories": "${rna_categorize_ref.output.categories}" } },
    { "name": "rna_publish", "taskReferenceName": "rna_publish_ref", "type": "SIMPLE", "inputParameters": { "releaseNotes": "${rna_generate_ref.output.releaseNotes}", "toTag": "${workflow.input.toTag}" } }
  ],
  "outputParameters": {
    "commitCount": "${rna_collect_ref.output.commitCount}",
    "categories": "${rna_categorize_ref.output.categories}",
    "published": "${rna_publish_ref.output.published}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
