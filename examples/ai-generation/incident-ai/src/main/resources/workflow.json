{
  "name": "iai_incident_ai",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["alertId", "serviceName", "severity"],
  "tasks": [
    { "name": "iai_detect", "taskReferenceName": "iai_detect_ref", "type": "SIMPLE", "inputParameters": { "alertId": "${workflow.input.alertId}", "serviceName": "${workflow.input.serviceName}" } },
    { "name": "iai_diagnose", "taskReferenceName": "iai_diagnose_ref", "type": "SIMPLE", "inputParameters": { "incidentDetails": "${iai_detect_ref.output.incidentDetails}" } },
    { "name": "iai_suggest_fix", "taskReferenceName": "iai_suggest_ref", "type": "SIMPLE", "inputParameters": { "diagnosis": "${iai_diagnose_ref.output.diagnosis}" } },
    { "name": "iai_execute_fix", "taskReferenceName": "iai_execute_ref", "type": "SIMPLE", "inputParameters": { "fix": "${iai_suggest_ref.output.suggestedFix}" } },
    { "name": "iai_verify", "taskReferenceName": "iai_verify_ref", "type": "SIMPLE", "inputParameters": { "fixApplied": "${iai_execute_ref.output.fixApplied}", "serviceName": "${workflow.input.serviceName}" } }
  ],
  "outputParameters": {
    "incidentId": "${iai_detect_ref.output.incidentId}",
    "diagnosis": "${iai_diagnose_ref.output.diagnosis}",
    "fixApplied": "${iai_execute_ref.output.fixApplied}",
    "verified": "${iai_verify_ref.output.verified}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
