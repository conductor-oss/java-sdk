{
  "name": "ollama_local_workflow",
  "description": "Local Ollama code review workflow with model check, generation, and post-processing",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["prompt", "model"],
  "tasks": [
    {
      "name": "ollama_check_model",
      "taskReferenceName": "ollama_check_model_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "model": "${workflow.input.model}",
        "ollamaHost": "http://localhost:11434"
      }
    },
    {
      "name": "ollama_generate",
      "taskReferenceName": "ollama_generate_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "prompt": "${workflow.input.prompt}",
        "model": "${ollama_check_model_ref.output.resolvedModel}",
        "ollamaHost": "http://localhost:11434",
        "options": {
          "temperature": 0.7,
          "top_k": 40,
          "top_p": 0.9,
          "num_predict": 256,
          "num_ctx": 4096
        }
      }
    },
    {
      "name": "ollama_post_process",
      "taskReferenceName": "ollama_post_process_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "response": "${ollama_generate_ref.output.response}"
      }
    }
  ],
  "outputParameters": {
    "review": "${ollama_post_process_ref.output.review}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 120
}
