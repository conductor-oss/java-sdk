{
  "name": "rag_pgvector_workflow",
  "version": 1,
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60,
  "schemaVersion": 2,
  "inputParameters": [
    "question",
    "table"
  ],
  "tasks": [
    {
      "name": "pgvec_embed",
      "taskReferenceName": "embed_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}"
      }
    },
    {
      "name": "pgvec_query",
      "taskReferenceName": "query_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "embedding": "${embed_ref.output.embedding}",
        "table": "${workflow.input.table}",
        "limit": 3,
        "distanceMetric": "cosine"
      }
    },
    {
      "name": "pgvec_generate",
      "taskReferenceName": "gen_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "rows": "${query_ref.output.rows}"
      }
    }
  ],
  "outputParameters": {
    "answer": "${gen_ref.output.answer}",
    "sqlUsed": "${query_ref.output.sqlQuery}"
  }
}
