{
  "name": "rag_milvus_workflow",
  "description": "RAG pipeline with Milvus: embed question, search vectors, generate answer",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["question", "collection"],
  "tasks": [
    {
      "name": "milvus_embed",
      "taskReferenceName": "embed_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}"
      }
    },
    {
      "name": "milvus_search",
      "taskReferenceName": "search_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "embedding": "${embed_ref.output.embedding}",
        "collection": "${workflow.input.collection}",
        "topK": 3,
        "metricType": "IP",
        "searchParams": {
          "nprobe": 16
        }
      }
    },
    {
      "name": "milvus_generate",
      "taskReferenceName": "gen_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "results": "${search_ref.output.results}"
      }
    }
  ],
  "outputParameters": {
    "answer": "${gen_ref.output.answer}",
    "milvusInfo": "${search_ref.output.collectionInfo}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
