{
  "name": "rag_chromadb_workflow",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["question", "collection"],
  "tasks": [
    {
      "name": "chroma_embed",
      "taskReferenceName": "embed_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}"
      }
    },
    {
      "name": "chroma_query",
      "taskReferenceName": "query_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "embedding": "${embed_ref.output.embedding}",
        "collection": "${workflow.input.collection}",
        "nResults": 3
      }
    },
    {
      "name": "chroma_generate",
      "taskReferenceName": "gen_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "results": "${query_ref.output.results}"
      }
    }
  ],
  "outputParameters": {
    "answer": "${gen_ref.output.answer}",
    "chromaInfo": "${query_ref.output.collectionInfo}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
