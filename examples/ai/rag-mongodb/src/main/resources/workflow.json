{
  "name": "rag_mongodb_workflow",
  "description": "RAG with MongoDB Atlas Vector Search — embed, search, generate",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["question", "database", "collection"],
  "tasks": [
    {
      "name": "mongo_embed",
      "taskReferenceName": "embed_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}"
      }
    },
    {
      "name": "mongo_vector_search",
      "taskReferenceName": "search_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "embedding": "${embed_ref.output.embedding}",
        "database": "${workflow.input.database}",
        "collection": "${workflow.input.collection}",
        "numCandidates": 100,
        "limit": 3
      }
    },
    {
      "name": "mongo_generate",
      "taskReferenceName": "gen_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "docs": "${search_ref.output.documents}"
      }
    }
  ],
  "outputParameters": {
    "answer": "${gen_ref.output.answer}",
    "searchMeta": "${search_ref.output.meta}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
