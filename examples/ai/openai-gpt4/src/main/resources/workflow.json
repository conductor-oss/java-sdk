{
  "name": "openai_gpt4_workflow",
  "description": "OpenAI GPT-4 chat completion pipeline: build request, call API, extract result",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["prompt", "systemMessage", "model"],
  "ownerEmail": "examples@orkes.io",
  "tasks": [
    {
      "name": "gpt4_build_request",
      "taskReferenceName": "gpt4_build_request_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "prompt": "${workflow.input.prompt}",
        "systemMessage": "${workflow.input.systemMessage}",
        "model": "${workflow.input.model}",
        "temperature": 0.7,
        "top_p": 1.0,
        "max_tokens": 1024,
        "frequency_penalty": 0.0,
        "presence_penalty": 0.0
      }
    },
    {
      "name": "gpt4_call_api",
      "taskReferenceName": "gpt4_call_api_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "requestBody": "${gpt4_build_request_ref.output.requestBody}"
      }
    },
    {
      "name": "gpt4_extract_result",
      "taskReferenceName": "gpt4_extract_result_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "apiResponse": "${gpt4_call_api_ref.output.apiResponse}"
      }
    }
  ],
  "outputParameters": {
    "summary": "${gpt4_extract_result_ref.output.summary}"
  }
}
