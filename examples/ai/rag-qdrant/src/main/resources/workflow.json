{
  "name": "rag_qdrant_workflow",
  "description": "RAG pipeline with Qdrant: embed question, search vectors with payload filtering, generate answer",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["question", "collection"],
  "tasks": [
    {
      "name": "qdrant_embed",
      "taskReferenceName": "embed_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}"
      }
    },
    {
      "name": "qdrant_search",
      "taskReferenceName": "search_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "embedding": "${embed_ref.output.embedding}",
        "collection": "${workflow.input.collection}",
        "limit": 3,
        "scoreThreshold": 0.7,
        "filter": {
          "must": [
            {
              "key": "status",
              "match": {
                "value": "active"
              }
            }
          ]
        }
      }
    },
    {
      "name": "qdrant_generate",
      "taskReferenceName": "gen_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "points": "${search_ref.output.points}"
      }
    }
  ],
  "outputParameters": {
    "answer": "${gen_ref.output.answer}",
    "collectionInfo": "${search_ref.output.collectionInfo}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
