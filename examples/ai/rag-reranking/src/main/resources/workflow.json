{
  "name": "rag_reranking_workflow",
  "description": "RAG with cross-encoder re-ranking between retrieval and generation",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["question", "retrieveK", "rerankTopN"],
  "tasks": [
    {
      "name": "rerank_embed",
      "taskReferenceName": "embed_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}"
      }
    },
    {
      "name": "rerank_retrieve",
      "taskReferenceName": "retrieve_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "embedding": "${embed_ref.output.embedding}",
        "topK": "${workflow.input.retrieveK}"
      }
    },
    {
      "name": "rerank_crossencoder",
      "taskReferenceName": "rerank_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "candidates": "${retrieve_ref.output.candidates}",
        "topN": "${workflow.input.rerankTopN}"
      }
    },
    {
      "name": "rerank_generate",
      "taskReferenceName": "gen_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "context": "${rerank_ref.output.reranked}"
      }
    }
  ],
  "outputParameters": {
    "answer": "${gen_ref.output.answer}",
    "retrievedCount": "${retrieve_ref.output.candidateCount}",
    "rerankedCount": "${rerank_ref.output.rerankedCount}",
    "rerankedDocs": "${rerank_ref.output.reranked}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
