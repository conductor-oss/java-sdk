{
  "name": "kbs_knowledge_base_sync",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["sourceUrl", "kbId"],
  "tasks": [
    { "name": "kbs_crawl", "taskReferenceName": "kbs_crawl_ref", "type": "SIMPLE", "inputParameters": { "sourceUrl": "${workflow.input.sourceUrl}" } },
    { "name": "kbs_extract", "taskReferenceName": "kbs_extract_ref", "type": "SIMPLE", "inputParameters": { "pages": "${kbs_crawl_ref.output.pages}" } },
    { "name": "kbs_update", "taskReferenceName": "kbs_update_ref", "type": "SIMPLE", "inputParameters": { "kbId": "${workflow.input.kbId}", "articles": "${kbs_extract_ref.output.articles}" } },
    { "name": "kbs_index", "taskReferenceName": "kbs_index_ref", "type": "SIMPLE", "inputParameters": { "kbId": "${workflow.input.kbId}", "updatedCount": "${kbs_update_ref.output.updatedCount}" } },
    { "name": "kbs_verify", "taskReferenceName": "kbs_verify_ref", "type": "SIMPLE", "inputParameters": { "kbId": "${workflow.input.kbId}", "indexedCount": "${kbs_index_ref.output.indexedCount}" } }
  ],
  "outputParameters": {
    "pagesCrawled": "${kbs_crawl_ref.output.pageCount}",
    "articlesUpdated": "${kbs_update_ref.output.updatedCount}",
    "searchReady": "${kbs_verify_ref.output.searchReady}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
