{
  "name": "code_rag_workflow",
  "version": 1,
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60,
  "schemaVersion": 2,
  "inputParameters": [
    "question",
    "language"
  ],
  "tasks": [
    {
      "name": "cr_parse_query",
      "taskReferenceName": "parse_query_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "language": "${workflow.input.language}"
      }
    },
    {
      "name": "cr_embed_code_query",
      "taskReferenceName": "embed_code_query_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "parsedIntent": "${parse_query_ref.output.intent}",
        "keywords": "${parse_query_ref.output.keywords}",
        "language": "${parse_query_ref.output.language}"
      }
    },
    {
      "name": "cr_search_code_index",
      "taskReferenceName": "search_code_index_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "embedding": "${embed_code_query_ref.output.embedding}",
        "codeFilter": "${embed_code_query_ref.output.codeFilter}"
      }
    },
    {
      "name": "cr_generate_code_answer",
      "taskReferenceName": "generate_code_answer_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "codeSnippets": "${search_code_index_ref.output.codeSnippets}"
      }
    }
  ],
  "outputParameters": {
    "answer": "${generate_code_answer_ref.output.answer}",
    "codeExample": "${generate_code_answer_ref.output.codeExample}",
    "snippetsUsed": "${search_code_index_ref.output.codeSnippets}"
  }
}
