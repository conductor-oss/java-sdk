{
  "name": "cbo_chatbot_orchestration",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["userId", "message", "sessionId"],
  "tasks": [
    { "name": "cbo_receive", "taskReferenceName": "cbo_receive_ref", "type": "SIMPLE", "inputParameters": { "userId": "${workflow.input.userId}", "message": "${workflow.input.message}", "sessionId": "${workflow.input.sessionId}" } },
    { "name": "cbo_understand_intent", "taskReferenceName": "cbo_intent_ref", "type": "SIMPLE", "inputParameters": { "message": "${workflow.input.message}", "context": "${cbo_receive_ref.output.context}" } },
    { "name": "cbo_generate_response", "taskReferenceName": "cbo_generate_ref", "type": "SIMPLE", "inputParameters": { "intent": "${cbo_intent_ref.output.intent}", "entities": "${cbo_intent_ref.output.entities}", "message": "${workflow.input.message}" } },
    { "name": "cbo_deliver", "taskReferenceName": "cbo_deliver_ref", "type": "SIMPLE", "inputParameters": { "userId": "${workflow.input.userId}", "response": "${cbo_generate_ref.output.response}", "sessionId": "${workflow.input.sessionId}" } }
  ],
  "outputParameters": {
    "intent": "${cbo_intent_ref.output.intent}",
    "response": "${cbo_generate_ref.output.response}",
    "delivered": "${cbo_deliver_ref.output.delivered}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
