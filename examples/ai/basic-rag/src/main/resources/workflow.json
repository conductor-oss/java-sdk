{
  "name": "basic_rag_workflow",
  "version": 1,
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 120,
  "inputParameters": [
    "question"
  ],
  "tasks": [
    {
      "name": "brag_embed_query",
      "taskReferenceName": "embed_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}"
      }
    },
    {
      "name": "brag_search_vectors",
      "taskReferenceName": "search_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "queryEmbedding": "${embed_ref.output.embedding}",
        "topK": 3
      }
    },
    {
      "name": "brag_generate_answer",
      "taskReferenceName": "gen_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "context": "${search_ref.output.documents}"
      }
    }
  ],
  "outputParameters": {
    "question": "${workflow.input.question}",
    "answer": "${gen_ref.output.answer}",
    "sources": "${search_ref.output.documents}",
    "embeddingDim": "${embed_ref.output.dimensions}"
  }
}
