{
  "name": "rag_elasticsearch_workflow",
  "description": "RAG workflow using Elasticsearch dense vector search (knn)",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["question", "index"],
  "tasks": [
    {
      "name": "es_embed",
      "taskReferenceName": "embed_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}"
      }
    },
    {
      "name": "es_knn_search",
      "taskReferenceName": "search_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "embedding": "${embed_ref.output.embedding}",
        "index": "${workflow.input.index}",
        "k": 3,
        "numCandidates": 50
      }
    },
    {
      "name": "es_generate",
      "taskReferenceName": "gen_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "hits": "${search_ref.output.hits}"
      }
    }
  ],
  "outputParameters": {
    "answer": "${gen_ref.output.answer}",
    "esStats": "${search_ref.output.stats}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
