{
  "name": "rag_pinecone_workflow",
  "description": "RAG pipeline with Pinecone: embed question, query vectors, generate answer",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["question", "namespace", "topK", "filter"],
  "tasks": [
    {
      "name": "pine_embed",
      "taskReferenceName": "pine_embed_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}"
      }
    },
    {
      "name": "pine_query",
      "taskReferenceName": "pine_query_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "embedding": "${pine_embed_ref.output.embedding}",
        "namespace": "${workflow.input.namespace}",
        "topK": "${workflow.input.topK}",
        "filter": "${workflow.input.filter}"
      }
    },
    {
      "name": "pine_generate",
      "taskReferenceName": "pine_generate_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "question": "${workflow.input.question}",
        "matches": "${pine_query_ref.output.matches}"
      }
    }
  ],
  "outputParameters": {
    "question": "${workflow.input.question}",
    "answer": "${pine_generate_ref.output.answer}",
    "matchCount": "${pine_query_ref.output.matches.length()}",
    "namespace": "${workflow.input.namespace}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
