{"name":"clinical_trials_workflow","description":"Clinical trials: screen, consent, randomize, monitor, analyze","version":1,"schemaVersion":2,"inputParameters":["trialId","participantId","condition"],"tasks":[{"name":"clt_screen","taskReferenceName":"clt_screen_ref","type":"SIMPLE","inputParameters":{"trialId":"${workflow.input.trialId}","participantId":"${workflow.input.participantId}","condition":"${workflow.input.condition}"}},{"name":"clt_consent","taskReferenceName":"clt_consent_ref","type":"SIMPLE","inputParameters":{"trialId":"${workflow.input.trialId}","participantId":"${workflow.input.participantId}","eligible":"${clt_screen_ref.output.eligible}"}},{"name":"clt_randomize","taskReferenceName":"clt_randomize_ref","type":"SIMPLE","inputParameters":{"trialId":"${workflow.input.trialId}","participantId":"${workflow.input.participantId}"}},{"name":"clt_monitor","taskReferenceName":"clt_monitor_ref","type":"SIMPLE","inputParameters":{"trialId":"${workflow.input.trialId}","participantId":"${workflow.input.participantId}","group":"${clt_randomize_ref.output.group}"}},{"name":"clt_analyze","taskReferenceName":"clt_analyze_ref","type":"SIMPLE","inputParameters":{"trialId":"${workflow.input.trialId}","participantId":"${workflow.input.participantId}","monitoringData":"${clt_monitor_ref.output.monitoringData}"}}],"outputParameters":{"trialId":"${workflow.input.trialId}","participantId":"${workflow.input.participantId}","group":"${clt_randomize_ref.output.group}","outcome":"${clt_analyze_ref.output.outcome}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
