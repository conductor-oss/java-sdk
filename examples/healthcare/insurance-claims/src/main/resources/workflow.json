{"name":"insurance_claims_workflow","description":"Insurance claims: submit, verify, adjudicate, pay, close","version":1,"schemaVersion":2,"inputParameters":["claimId","patientId","providerId","amount","procedureCode"],"tasks":[{"name":"clm_submit","taskReferenceName":"clm_submit_ref","type":"SIMPLE","inputParameters":{"claimId":"${workflow.input.claimId}","patientId":"${workflow.input.patientId}","providerId":"${workflow.input.providerId}","amount":"${workflow.input.amount}","procedureCode":"${workflow.input.procedureCode}"}},{"name":"clm_verify","taskReferenceName":"clm_verify_ref","type":"SIMPLE","inputParameters":{"claimId":"${workflow.input.claimId}","patientId":"${workflow.input.patientId}","procedureCode":"${workflow.input.procedureCode}"}},{"name":"clm_adjudicate","taskReferenceName":"clm_adjudicate_ref","type":"SIMPLE","inputParameters":{"claimId":"${workflow.input.claimId}","amount":"${workflow.input.amount}","eligible":"${clm_verify_ref.output.eligible}","coverage":"${clm_verify_ref.output.coverage}"}},{"name":"clm_pay","taskReferenceName":"clm_pay_ref","type":"SIMPLE","inputParameters":{"claimId":"${workflow.input.claimId}","providerId":"${workflow.input.providerId}","approvedAmount":"${clm_adjudicate_ref.output.approvedAmount}"}},{"name":"clm_close","taskReferenceName":"clm_close_ref","type":"SIMPLE","inputParameters":{"claimId":"${workflow.input.claimId}","paidAmount":"${clm_pay_ref.output.paidAmount}"}}],"outputParameters":{"claimId":"${workflow.input.claimId}","approvedAmount":"${clm_adjudicate_ref.output.approvedAmount}","paidAmount":"${clm_pay_ref.output.paidAmount}","status":"${clm_close_ref.output.claimStatus}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
