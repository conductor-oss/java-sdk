{"name":"lab_results_workflow","description":"Lab results: collect, process, analyze, report, notify","version":1,"schemaVersion":2,"inputParameters":["orderId","patientId","testType"],"tasks":[{"name":"lab_collect_sample","taskReferenceName":"lab_collect_ref","type":"SIMPLE","inputParameters":{"orderId":"${workflow.input.orderId}","patientId":"${workflow.input.patientId}","testType":"${workflow.input.testType}"}},{"name":"lab_process","taskReferenceName":"lab_process_ref","type":"SIMPLE","inputParameters":{"sampleId":"${lab_collect_ref.output.sampleId}","testType":"${workflow.input.testType}"}},{"name":"lab_analyze","taskReferenceName":"lab_analyze_ref","type":"SIMPLE","inputParameters":{"sampleId":"${lab_collect_ref.output.sampleId}","processedData":"${lab_process_ref.output.processedData}"}},{"name":"lab_report","taskReferenceName":"lab_report_ref","type":"SIMPLE","inputParameters":{"orderId":"${workflow.input.orderId}","patientId":"${workflow.input.patientId}","results":"${lab_analyze_ref.output.results}"}},{"name":"lab_notify","taskReferenceName":"lab_notify_ref","type":"SIMPLE","inputParameters":{"orderId":"${workflow.input.orderId}","patientId":"${workflow.input.patientId}","reportId":"${lab_report_ref.output.reportId}","critical":"${lab_analyze_ref.output.critical}"}}],"outputParameters":{"orderId":"${workflow.input.orderId}","results":"${lab_analyze_ref.output.results}","reportId":"${lab_report_ref.output.reportId}","notified":"${lab_notify_ref.output.notified}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
