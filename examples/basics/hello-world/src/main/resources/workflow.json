{
  "name": "hello_world_workflow",
  "description": "The simplest Conductor workflow — one task, one worker",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["name"],
  "tasks": [
    {
      "name": "greet",
      "taskReferenceName": "greet_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "name": "${workflow.input.name}"
      }
    }
  ],
  "outputParameters": {
    "greeting": "${greet_ref.output.greeting}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
