{
  "name": "event_sourcing_workflow",
  "description": "Event sourcing with append-only event log and state rebuild",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["aggregateId", "eventType", "eventData"],
  "tasks": [
    {"name": "es_validate_event", "taskReferenceName": "validate_ref", "type": "SIMPLE",
      "inputParameters": {"aggregateId": "${workflow.input.aggregateId}", "eventType": "${workflow.input.eventType}", "eventData": "${workflow.input.eventData}"}},
    {"name": "es_append_event", "taskReferenceName": "append_ref", "type": "SIMPLE",
      "inputParameters": {"aggregateId": "${workflow.input.aggregateId}", "event": "${validate_ref.output.validatedEvent}"}},
    {"name": "es_rebuild_state", "taskReferenceName": "state_ref", "type": "SIMPLE",
      "inputParameters": {"aggregateId": "${workflow.input.aggregateId}", "latestVersion": "${append_ref.output.version}"}},
    {"name": "es_publish_event", "taskReferenceName": "publish_ref", "type": "SIMPLE",
      "inputParameters": {"eventId": "${append_ref.output.eventId}", "aggregateId": "${workflow.input.aggregateId}"}}
  ],
  "outputParameters": {"eventId": "${append_ref.output.eventId}", "version": "${append_ref.output.version}", "currentState": "${state_ref.output.state}"},
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
