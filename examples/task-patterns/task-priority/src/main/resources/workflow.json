{
  "name": "priority_demo",
  "description": "Workflow priority demo — priority levels 0-99 (higher = more important).",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["requestId", "priority"],
  "tasks": [
    {
      "name": "pri_process",
      "taskReferenceName": "pri_process_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "requestId": "${workflow.input.requestId}",
        "priority": "${workflow.input.priority}"
      }
    }
  ],
  "outputParameters": {
    "requestId": "${pri_process_ref.output.requestId}",
    "processed": "${pri_process_ref.output.processed}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
