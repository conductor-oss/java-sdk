{
  "name": "map_reduce_demo",
  "description": "MapReduce Pattern -- Splits log files into parallel analysis tasks using FORK_JOIN_DYNAMIC, then aggregates results in a reduce step.",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["logFiles"],
  "tasks": [
    {
      "name": "mr_map",
      "taskReferenceName": "mr_map_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "logFiles": "${workflow.input.logFiles}"
      }
    },
    {
      "name": "dynamic_fork",
      "taskReferenceName": "dynamic_fork_ref",
      "type": "FORK_JOIN_DYNAMIC",
      "inputParameters": {
        "dynamicForkTasksParam": "dynamicTasks",
        "dynamicForkTasksInputParamName": "dynamicTasksInput"
      },
      "dynamicForkTasksParam": "dynamicTasks",
      "dynamicForkTasksInputParamName": "dynamicTasksInput"
    },
    {
      "name": "dynamic_join",
      "taskReferenceName": "dynamic_join_ref",
      "type": "JOIN"
    },
    {
      "name": "mr_reduce",
      "taskReferenceName": "mr_reduce_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "mapResults": "${dynamic_join_ref.output}",
        "fileCount": "${mr_map_ref.output.dynamicTasks.length()}"
      }
    }
  ],
  "outputParameters": {
    "report": "${mr_reduce_ref.output.report}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 120
}
