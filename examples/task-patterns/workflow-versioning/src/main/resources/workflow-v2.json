{
  "name": "versioned_workflow",
  "description": "Versioned workflow V2 — calculation + bonus. Returns (value * 2) + 10.",
  "version": 2,
  "schemaVersion": 2,
  "inputParameters": ["value"],
  "tasks": [
    {
      "name": "ver_calc",
      "taskReferenceName": "ver_calc_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "value": "${workflow.input.value}"
      }
    },
    {
      "name": "ver_bonus",
      "taskReferenceName": "ver_bonus_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "baseResult": "${ver_calc_ref.output.result}"
      }
    }
  ],
  "outputParameters": {
    "result": "${ver_bonus_ref.output.result}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
