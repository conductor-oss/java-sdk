{
  "name": "cma_commit_analysis",
  "version": 1,
  "schemaVersion": 2,
  "inputParameters": ["repoName", "branch", "days"],
  "tasks": [
    { "name": "cma_parse_commits", "taskReferenceName": "cma_parse_ref", "type": "SIMPLE", "inputParameters": { "repoName": "${workflow.input.repoName}", "branch": "${workflow.input.branch}", "days": "${workflow.input.days}" } },
    { "name": "cma_classify", "taskReferenceName": "cma_classify_ref", "type": "SIMPLE", "inputParameters": { "commits": "${cma_parse_ref.output.commits}" } },
    { "name": "cma_detect_patterns", "taskReferenceName": "cma_patterns_ref", "type": "SIMPLE", "inputParameters": { "classified": "${cma_classify_ref.output.classified}" } },
    { "name": "cma_report", "taskReferenceName": "cma_report_ref", "type": "SIMPLE", "inputParameters": { "patterns": "${cma_patterns_ref.output.patterns}", "classified": "${cma_classify_ref.output.classified}" } }
  ],
  "outputParameters": {
    "totalCommits": "${cma_parse_ref.output.commitCount}",
    "classification": "${cma_classify_ref.output.summary}",
    "patterns": "${cma_patterns_ref.output.patterns}",
    "report": "${cma_report_ref.output.report}"
  },
  "ownerEmail": "examples@orkes.io",
  "timeoutSeconds": 60
}
