{"name":"tpl_travel_policy","description":"Travel policy with SWITCH for compliant/exception.","version":1,"schemaVersion":2,"inputParameters":["employeeId","bookingType","amount","policyTier"],"tasks":[{"name":"tpl_check","taskReferenceName":"tpl_check_ref","type":"SIMPLE","inputParameters":{"bookingType":"${workflow.input.bookingType}","amount":"${workflow.input.amount}","policyTier":"${workflow.input.policyTier}"}},{"name":"policy_route","taskReferenceName":"tpl_switch_ref","type":"SWITCH","evaluatorType":"value-param","expression":"switchCaseValue","inputParameters":{"switchCaseValue":"${tpl_check_ref.output.complianceResult}"},"decisionCases":{"compliant":[{"name":"tpl_compliant","taskReferenceName":"tpl_comp_ref","type":"SIMPLE","inputParameters":{"bookingType":"${workflow.input.bookingType}"}}],"exception":[{"name":"tpl_exception","taskReferenceName":"tpl_exc_ref","type":"SIMPLE","inputParameters":{"bookingType":"${workflow.input.bookingType}","amount":"${workflow.input.amount}","reason":"${tpl_check_ref.output.reason}"}}]},"defaultCase":[]},{"name":"tpl_process","taskReferenceName":"tpl_process_ref","type":"SIMPLE","inputParameters":{"employeeId":"${workflow.input.employeeId}","complianceResult":"${tpl_check_ref.output.complianceResult}"}}],"outputParameters":{"complianceResult":"${tpl_check_ref.output.complianceResult}","processed":"${tpl_process_ref.output.processed}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
