{"name":"crl_car_rental","description":"Car rental: search, select, book, pickup, return.","version":1,"schemaVersion":2,"inputParameters":["travelerId","location","pickupDate","returnDate"],"tasks":[{"name":"crl_search","taskReferenceName":"crl_search_ref","type":"SIMPLE","inputParameters":{"location":"${workflow.input.location}","pickupDate":"${workflow.input.pickupDate}"}},{"name":"crl_select","taskReferenceName":"crl_select_ref","type":"SIMPLE","inputParameters":{"available":"${crl_search_ref.output.available}"}},{"name":"crl_book","taskReferenceName":"crl_book_ref","type":"SIMPLE","inputParameters":{"vehicle":"${crl_select_ref.output.selected}","travelerId":"${workflow.input.travelerId}"}},{"name":"crl_pickup","taskReferenceName":"crl_pickup_ref","type":"SIMPLE","inputParameters":{"reservationId":"${crl_book_ref.output.reservationId}"}},{"name":"crl_return","taskReferenceName":"crl_return_ref","type":"SIMPLE","inputParameters":{"reservationId":"${crl_book_ref.output.reservationId}"}}],"outputParameters":{"reservationId":"${crl_book_ref.output.reservationId}","vehicle":"${crl_select_ref.output.selected.model}","totalCost":"${crl_return_ref.output.totalCost}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
