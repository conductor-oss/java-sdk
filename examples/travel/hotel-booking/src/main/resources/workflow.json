{"name":"htl_hotel_booking","description":"Hotel booking: search, filter, book, confirm, reminder.","version":1,"schemaVersion":2,"inputParameters":["travelerId","city","checkIn","checkOut"],"tasks":[{"name":"htl_search","taskReferenceName":"htl_search_ref","type":"SIMPLE","inputParameters":{"city":"${workflow.input.city}","checkIn":"${workflow.input.checkIn}","checkOut":"${workflow.input.checkOut}"}},{"name":"htl_filter","taskReferenceName":"htl_filter_ref","type":"SIMPLE","inputParameters":{"hotels":"${htl_search_ref.output.hotels}"}},{"name":"htl_book","taskReferenceName":"htl_book_ref","type":"SIMPLE","inputParameters":{"hotel":"${htl_filter_ref.output.bestMatch}","travelerId":"${workflow.input.travelerId}"}},{"name":"htl_confirm","taskReferenceName":"htl_confirm_ref","type":"SIMPLE","inputParameters":{"reservationId":"${htl_book_ref.output.reservationId}"}},{"name":"htl_reminder","taskReferenceName":"htl_remind_ref","type":"SIMPLE","inputParameters":{"reservationId":"${htl_book_ref.output.reservationId}","travelerId":"${workflow.input.travelerId}"}}],"outputParameters":{"reservationId":"${htl_book_ref.output.reservationId}","hotelName":"${htl_filter_ref.output.bestMatch.name}","nightlyRate":"${htl_filter_ref.output.bestMatch.rate}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
