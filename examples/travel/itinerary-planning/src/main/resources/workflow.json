{"name":"itp_itinerary_planning","description":"Itinerary planning: preferences, search, optimize, book, finalize.","version":1,"schemaVersion":2,"inputParameters":["travelerId","destination","days"],"tasks":[{"name":"itp_preferences","taskReferenceName":"itp_pref_ref","type":"SIMPLE","inputParameters":{"travelerId":"${workflow.input.travelerId}"}},{"name":"itp_search","taskReferenceName":"itp_search_ref","type":"SIMPLE","inputParameters":{"destination":"${workflow.input.destination}","days":"${workflow.input.days}","preferences":"${itp_pref_ref.output.preferences}"}},{"name":"itp_optimize","taskReferenceName":"itp_opt_ref","type":"SIMPLE","inputParameters":{"options":"${itp_search_ref.output.options}"}},{"name":"itp_book","taskReferenceName":"itp_book_ref","type":"SIMPLE","inputParameters":{"itinerary":"${itp_opt_ref.output.optimizedItinerary}"}},{"name":"itp_finalize","taskReferenceName":"itp_final_ref","type":"SIMPLE","inputParameters":{"bookingIds":"${itp_book_ref.output.bookingIds}","travelerId":"${workflow.input.travelerId}"}}],"outputParameters":{"itineraryId":"${itp_final_ref.output.itineraryId}","totalCost":"${itp_book_ref.output.totalCost}"},"ownerEmail":"examples@orkes.io","timeoutSeconds":60}
